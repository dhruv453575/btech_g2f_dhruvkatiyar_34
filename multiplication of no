#include <stdio.h>

int main() {
    int num, i;

   
    printf("Enter an integer to print its multiplication table: ");
    scanf("%d", &num);

    printf("Multiplication Table of %d:\n", num);

    // Loop from 1 to 10 to calculate and print the table
    for (i = 1; i <= 10; i++) {
        printf("%d x %d = %d\n", num, i, num * i);
    }

    return 0;
}
